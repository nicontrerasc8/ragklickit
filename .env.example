# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Local and production AI: Groq only
AI_PROVIDER=groq
WEB_RESEARCH_PROVIDER=groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=openai/gpt-oss-120b
GROQ_WEB_SEARCH_MODEL=groq/compound-mini

# Optional OpenAI image/PDF fallback
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_PDF_MODEL=gpt-4o-mini

# Optional local Ollama fallback
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=gpt-oss:120b-cloud
OLLAMA_EMBED_MODEL=nomic-embed-text

# OCR.space
OCR_SPACE_API_KEY=
OCR_SPACE_ENGINE=2
OCR_SPACE_LANGUAGE=spa
